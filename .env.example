# Copy to .env and fill in real values before running `docker compose up`.

POSTGRES_USER=vsp
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=vsp_inventory

# Long random string - e.g. `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first backend startup if it doesn't already exist.
# Change this password after first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# --- Access via Cloudflare Tunnel (see docker/cloudflared/README.md for full setup) ---
# The app is served at https://APP_HOSTNAME, e.g. inventory.indiconvision.com, both from
# your LAN and remotely - Cloudflare's edge terminates TLS and proxies in over an
# outbound-only tunnel, so no port forwarding and no per-device cert setup is needed.
# Protect this with a Cloudflare Access policy (see the README) since it's internet-reachable.
APP_HOSTNAME=inventory.indiconvision.com

# Token for the tunnel you create in the Cloudflare Zero Trust dashboard
# (Networks -> Tunnels -> Create a tunnel -> Docker).
CLOUDFLARE_TUNNEL_TOKEN=change-me-to-your-real-tunnel-token
