# Copy to .env and fill in real values before running `docker compose up`.

POSTGRES_USER=vsp
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=vsp_inventory

# Long random string - e.g. `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first backend startup if it doesn't already exist.
# Change this password after first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# --- Fronted by your own reverse proxy (e.g. Nginx Proxy Manager) ---
# This stack does NOT terminate TLS itself - `frontend` serves plain HTTP on HTTP_PORT.
# Point your reverse proxy's forward target at <unraid-ip>:HTTP_PORT, with SSL/your
# hostname/tunnel handled entirely on that side. See README.md for the exact settings.
APP_HOSTNAME=inventory.indiconvision.com

# Unraid's webGUI usually owns ports 80/443, so this defaults to an alternate port.
HTTP_PORT=8080

# Which published backend/frontend image tag to pull from ghcr.io/fsteerzer88 on
# `docker compose pull`. GitHub Actions publishes `latest` (and `sha-<short-sha>` for
# pinning/rollback) on every push to main that passes CI. Not used when building locally.
IMAGE_TAG=latest
