# Copy to .env and fill in real values before running `docker compose up`.

POSTGRES_USER=vsp
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=vsp_inventory

# Long random string - e.g. `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first backend startup if it doesn't already exist.
# Change this password after first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# --- TLS via SWAG + Cloudflare DNS-01 (see docker/swag/README.md for full setup) ---
# The app is served at https://<APP_SUBDOMAIN>.<CLOUDFLARE_ROOT_DOMAIN>, e.g. inventory.indiconvision.com.
# Traffic never leaves your LAN - Cloudflare is only used to prove domain ownership for the cert.
CLOUDFLARE_ROOT_DOMAIN=indiconvision.com
APP_SUBDOMAIN=inventory
APP_HOSTNAME=inventory.indiconvision.com
LETSENCRYPT_EMAIL=you@example.com
# Set to true while testing to avoid Let's Encrypt's real rate limits, then switch to false.
LETSENCRYPT_STAGING=false

# Unraid's default user/group (nobody:users). Adjust if deploying elsewhere.
PUID=99
PGID=100
TZ=Etc/UTC

# NOTE for Unraid: the Unraid webGUI itself usually owns ports 80/443 on the host,
# so this defaults to alternate ports. Change back to 80/443 only if you've freed
# them up (e.g. moved the Unraid GUI to a different port).
HTTP_PORT=8080
HTTPS_PORT=8443
