# Copy to .env and fill in real values before running `docker compose up`.

POSTGRES_USER=vsp
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=vsp_inventory

# Long random string - e.g. `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first backend startup if it doesn't already exist.
# Change this password after first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# Stable LAN hostname you'll point mkcert at and browse to (see docker/reverse-proxy/README.md).
APP_HOSTNAME=inventory.lan

HTTP_PORT=80
HTTPS_PORT=443
